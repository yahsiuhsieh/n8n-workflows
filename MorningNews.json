    {
      "parameters": {
        "jsCode": "// 取幾筆資料\nconst num = 10;\n\n// 取得所有輸入的 items\nconst items = $(\"MergeAllRSS\").all()\n\n// 要分組的 field 類別\nconst groups = {};\n\n// 分組 (按照 field)\nfor (const item of items) {\n  const field = item.json.field;\n\n  if (!groups[field]) {\n    groups[field] = [];\n  }\n  groups[field].push(item);\n}\n\n// 為每個 field 取最多 10 筆\nlet result = [];\nfor (const field in groups) {\n  const tenItems = groups[field].slice(0, num);\n  result.push(...tenItems);\n}\n\nreturn result;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
